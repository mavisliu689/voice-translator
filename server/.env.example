# 後端伺服器配置
PORT=3001
NODE_ENV=development

# Google Translation API Key (basic 模式必須設定)
GOOGLE_TRANSLATE_API_KEY=your_api_key_here

# Gemini API Key（premium 模式必須設定；未設定時後台無法切到 premium）
# 取得：https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 前端應用 URL (CORS 設定)
FRONTEND_URL=http://localhost:5173

# 速率限制設定（可選）
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# 日誌級別（可選）
LOG_LEVEL=info

# 初始管理員（首次啟動時若 DB 無管理員會自動建立）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=請改成你的密碼

# JWT 簽章金鑰（必填，請改成隨機長字串）
JWT_SECRET=請改成隨機長字串