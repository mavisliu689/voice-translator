# Google Cloud Translation API Key
# 取得方式：
# 1. 前往 https://console.cloud.google.com
# 2. 建立新專案或選擇現有專案
# 3. 啟用 Cloud Translation API
# 4. 前往 APIs & Services → Credentials
# 5. 點擊 "Create Credentials" → "API Key"
# 6. 複製 API Key 並貼到下方
# 7. 建議限制 API Key 的使用範圍（限制特定 API 和網域）

VITE_GOOGLE_TRANSLATE_API_KEY=your_google_cloud_translation_api_key_here

# 注意事項：
# - 請勿將真實的 API Key 提交到版本控制系統
# - 生產環境應使用後端伺服器代理 API 請求
# - 確保 .env 檔案已加入 .gitignore