# ─────────────────────────────────────────────────────────────
# 前端建置（dev 用；生產同源可留空）
# ─────────────────────────────────────────────────────────────
VITE_BACKEND_URL=http://localhost:3001

# 舊版配置（不再使用，已改為後端 API；勿放真實 key，VITE_ 會被打包進前端）
# VITE_GOOGLE_TRANSLATE_API_KEY=

# ─────────────────────────────────────────────────────────────
# docker-compose.yml 會把以下變數代入容器（請在此檔填真實值，勿入版控）
# ─────────────────────────────────────────────────────────────

# 標準（basic）文字翻譯 — Google Cloud Translation API key
GOOGLE_TRANSLATE_API_KEY=

# 高品質（premium 文字）與 Live 即時語音翻譯 — Gemini API key
# 注意：這與上面 GOOGLE_TRANSLATE_API_KEY 是「不同的 key、不同的服務」。
# 沒設定它，後台「高品質」與「Live」會顯示「尚未設定」。
# 取得：https://aistudio.google.com/apikey（Live 需要 gemini-3.5-live-translate-preview 存取權）
GEMINI_API_KEY=

# 認證
JWT_SECRET=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# 允許嵌入/CORS 來源（逗號分隔；預設 * 允許全部）
ALLOWED_ORIGINS=*
